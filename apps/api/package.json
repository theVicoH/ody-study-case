{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "NODE_ENV=production bun build src/index.ts --target=bun --outdir=.output",
    "start": "bun run .output/index.js",
    "lint": "oxlint --config .oxlintrc.json src/ && eslint src/",
    "lint:fix": "oxlint --fix --config .oxlintrc.json src/ && eslint --fix src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@scalar/hono-api-reference": "0.10.5",
    "@workspace/application": "workspace:*",
    "@workspace/database": "workspace:*",
    "@workspace/domain": "workspace:*",
    "@workspace/shared": "workspace:*",
    "better-auth": "1.5.6",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.44.1",
    "hono": "4.12.8",
    "hono-pino": "0.10.3",
    "pino": "10.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@hono/zod-openapi": "1.2.4",
    "@types/bun": "1.3.11",
    "bun-types": "1.3.11",
    "@types/pino": "7.0.5",
    "@vitest/coverage-v8": "3.2.4",
    "vite": "7.2.4",
    "@workspace/lint-plugin-custom": "workspace:*",
    "@workspace/shared": "workspace:*",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.4"
  }
}