{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": [],
    "paths": {
      "@workspace/threejs": ["./src/index.ts"],
      "@workspace/threejs/*": ["./src/*"],
      "@/*": ["./src/*", "../client/src/*", "../ui/src/*"],
      "@workspace/client": ["../client/src/index.ts"],
      "@workspace/client/*": ["../client/src/*"],
      "@workspace/ui": ["../ui/src/index.ts"],
      "@workspace/ui/*": ["../ui/src/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist", "vitest.config.ts", "vitest.config.js"]
}
