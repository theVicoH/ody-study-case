{
  "name": "@workspace/database",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "oxlint --config .oxlintrc.json src/ && eslint src/",
    "lint:fix": "oxlint --fix --config .oxlintrc.json src/ && eslint --fix src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "bun --env-file ../../.env drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun --env-file ../../.env drizzle-kit migrate --config drizzle.config.ts",
    "db:studio": "bun --env-file ../../.env drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "0.44.1",
    "postgres": "3.4.8"
  },
  "devDependencies": {
    "@workspace/lint-plugin-custom": "workspace:*",
    "@vitest/coverage-v8": "3.2.4",
    "drizzle-kit": "0.31.1",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.4",
    "@workspace/shared": "workspace:*"
  }
}
