{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [],
    "paths": {
      "@/*": [
        "./src/*",
        "../domain/src/*",
        "../database/src/*",
        "../application/src/*",
        "../auth/src/*",
        "../email/src/*",
        "../shared/src/*"
      ],
      "@workspace/domain": ["../domain/src/index.ts"],
      "@workspace/domain/*": ["../domain/src/*"],
      "@workspace/database": ["../database/src/index.ts"],
      "@workspace/database/*": ["../database/src/*"],
      "@workspace/application": ["../application/src/index.ts"],
      "@workspace/application/*": ["../application/src/*"],
      "@workspace/auth": ["../auth/src/index.ts"],
      "@workspace/auth/*": ["../auth/src/*"],
      "@workspace/email": ["../email/src/index.ts"],
      "@workspace/email/*": ["../email/src/*"],
      "@workspace/shared": ["../shared/src/index.ts"],
      "@workspace/shared/*": ["../shared/src/*"],
      "@workspace/client/*": ["../client/src/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist", "vitest.config.ts", "vitest.config.js"]
}
